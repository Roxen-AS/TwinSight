# ═══════════════════════════════════════════════════
# TwinSight — Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════

# ── Application ─────────────────────────────────────
ENVIRONMENT=development
APP_NAME=TwinSight
APP_VERSION=1.0.0

# ── Security ────────────────────────────────────────
JWT_SECRET=change_me_to_a_random_64_char_string_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── Database ────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=twinsight
POSTGRES_USER=twinsight
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql+asyncpg://twinsight:your_password@localhost:5432/twinsight

# ── Redis ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://:your_redis_password@localhost:6379/0

# ── AI / LLM ────────────────────────────────────────
# Required for AI Analyzer feature
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── CORS ────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Telemetry ────────────────────────────────────────
TELEMETRY_BROADCAST_INTERVAL_MS=3000

# ── Feature Flags ───────────────────────────────────
ENABLE_AI_ANALYZER=true
ENABLE_DIGITAL_TWIN=true
ENABLE_AUTONOMOUS_MODE=true
